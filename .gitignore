/target
**/*.rs.bk
# capture harness (oracle/) — networked, local-only artifacts
oracle/.venv/
oracle/.env
*.env
.DS_Store
__pycache__/
*.pyc

# replay diagnostics (regenerated by capture.py --replay)
oracle/fixtures/*/graph_state.replay.json
oracle/fixtures/*/retrieval.replay.json

# nacre-node build artifacts
crates/nacre-node/node_modules/
crates/nacre-node/*.node
crates/nacre-node/index.js
crates/nacre-node/index.d.ts
