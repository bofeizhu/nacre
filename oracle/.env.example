# Copy to oracle/.env and fill in. oracle/.env is gitignored — NEVER commit
# real keys. capture.py loads this automatically; shell env vars win on
# conflict.

# --- LLM: DeepSeek (any OpenAI-compatible endpoint works) ---
CAPTURE_LLM_BASE_URL=https://api.deepseek.com
CAPTURE_LLM_API_KEY=sk-deepseek-...
CAPTURE_LLM_MODEL=deepseek-chat
# Optional cheaper tier for small judgment calls (defaults to CAPTURE_LLM_MODEL):
# CAPTURE_LLM_SMALL_MODEL=deepseek-chat
# DeepSeek doesn't support json_schema output; json_object is the default
# whenever CAPTURE_LLM_BASE_URL is set. Uncomment only for providers that do:
# CAPTURE_LLM_STRUCTURED_OUTPUT=json_schema

# --- Embeddings: OpenAI (DeepSeek has no embeddings endpoint) ---
# Used for embeddings ONLY when CAPTURE_LLM_* points elsewhere.
OPENAI_API_KEY=sk-...
# Or a dedicated embeddings provider instead:
# CAPTURE_EMBEDDER_API_KEY=...
# CAPTURE_EMBEDDER_BASE_URL=...
# CAPTURE_EMBEDDER_MODEL=text-embedding-3-small
